# ─────────────────────────────────────────────
# Core (required)
# ─────────────────────────────────────────────
SETUP_PASSWORD=                     # Protects the /setup UI
OPENCLAW_GATEWAY_TOKEN=             # Bearer for the openclaw gateway AND every inbound /api/* call (per-shard)

# ─────────────────────────────────────────────
# Storage paths (set automatically on Railway via railway.toml)
# ─────────────────────────────────────────────
OPENCLAW_STATE_DIR=/data/.openclaw

# ─────────────────────────────────────────────
# Orchestrator integration — shared-gateway / multi-tenant model
# ─────────────────────────────────────────────
ORCHESTRATOR_URL=                   # Private orchestrator URL (RAILWAY_PRIVATE_DOMAIN)
ORCHESTRATOR_SECRET=                # Per-shard bidirectional Bearer for /internal/* calls
SHARD_ID=                           # Set automatically by the orchestrator at shard provision time; identifies this shard for the boot-time tenant-mapping fetch and the provision callback

# ─────────────────────────────────────────────
# Auto-setup (set automatically by the orchestrator during shard provisioning)
# ─────────────────────────────────────────────
OPENCLAW_AUTO_SETUP=                # Set to "true" to skip the setup UI and auto-configure on first boot
OPENCLAW_AUTH_CHOICE=               # Auth provider (e.g. apiKey, openai-api-key, gemini-api-key)
OPENCLAW_AUTH_SECRET=               # API key for the chosen auth provider
OPENCLAW_FLOW=quickstart            # Onboarding flow (default: quickstart)
OPENCLAW_DEFAULT_MODEL=             # Primary model for all agents — "provider/model" (e.g. google/gemini-2.5-pro)

# ─────────────────────────────────────────────
# Model fallbacks (optional) — provider-agnostic chain for LLM-provider failover.
# OPENCLAW_FALLBACK_MODELS: ordered, comma-separated "provider/model" list tried
# after the primary fails (auth/rate-limit/overload/timeout/billing). Empty =
# strict (primary only, no fallback). Primary + each fallback may be any
# supported provider in any combination (all-same or mixed).
# A cross-provider fallback needs its key via OPENCLAW_FALLBACK_KEY_<PROVIDER>
# (aliased into the provider's runtime env var, kept in env, never written to
# disk). Same-provider fallbacks reuse the primary's auth — no extra key needed.
# Supported providers: ANTHROPIC → ANTHROPIC_API_KEY, OPENAI → OPENAI_API_KEY,
# GOOGLE → GEMINI_API_KEY.
# ─────────────────────────────────────────────
OPENCLAW_FALLBACK_MODELS=           # e.g. anthropic/claude-sonnet-4-6, openai/gpt-5.1
OPENCLAW_FALLBACK_KEY_ANTHROPIC=    # Anthropic key — only if a fallback uses anthropic/… and it isn't the primary
OPENCLAW_FALLBACK_KEY_OPENAI=       # OpenAI key — only if a fallback uses openai/… and it isn't the primary
OPENCLAW_FALLBACK_KEY_GOOGLE=       # Google key — only if a fallback uses google/… and it isn't the primary

# ─────────────────────────────────────────────
# Web search (optional) — set the provider-native key directly on the service env.
# OpenClaw auto-detects the provider from whichever key is present.
# Examples: BRAVE_API_KEY, TAVILY_API_KEY, EXA_API_KEY, PERPLEXITY_API_KEY.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Channel tokens — DEFERRED in v1 (shared-gateway design out-of-scope).
# Left here for forward compatibility with single-tenant deployments.
# ─────────────────────────────────────────────
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_DISCORD_TOKEN=
OPENCLAW_SLACK_BOT_TOKEN=
OPENCLAW_SLACK_APP_TOKEN=

# ─────────────────────────────────────────────
# Injected automatically by Railway — do not set manually
# ─────────────────────────────────────────────
# PORT
# RAILWAY_PUBLIC_DOMAIN
# RAILWAY_PRIVATE_DOMAIN
# RAILWAY_GIT_COMMIT_SHA
